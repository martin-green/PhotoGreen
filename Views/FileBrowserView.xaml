<UserControl x:Class="PhotoGreen.Views.FileBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PhotoGreen.ViewModels" Background="#1E1E1E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Current path + Up button -->
        <DockPanel Grid.Row="0" Margin="4">
            <Button DockPanel.Dock="Left" Content="?" Width="28" Height="28"
                    Command="{Binding NavigateUpCommand}" ToolTip="Navigate Up" Margin="0,0,4,0"/>
            <TextBlock Text="{Binding CurrentDirectory}" VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" ToolTip="{Binding CurrentDirectory}"/>
        </DockPanel>

        <!-- Folder tree -->
        <TreeView Grid.Row="1" ItemsSource="{Binding RootFolders}" BorderThickness="0,1,0,1">
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                </Style>
            </TreeView.ItemContainerStyle>
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate DataType="{x:Type vm:FolderNode}" ItemsSource="{Binding Children}">
                    <TextBlock Text="{Binding DisplayName}" Padding="2">
                        <TextBlock.InputBindings>
                            <MouseBinding Gesture="LeftDoubleClick"
                                          Command="{Binding DataContext.NavigateToDirectoryCommand, RelativeSource={RelativeSource AncestorType=TreeView}}"
                                          CommandParameter="{Binding FullPath}"/>
                        </TextBlock.InputBindings>
                    </TextBlock>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

        <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch"
                      Background="Transparent" Cursor="SizeNS"/>

        <!-- Image file list -->
        <ListBox Grid.Row="3" ItemsSource="{Binding ImageGroups}"
                 SelectedItem="{Binding SelectedGroup}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:FolderNode}">
                    <StackPanel Orientation="Horizontal" Margin="4">
                        <Border Width="60" Height="60" Background="#333" CornerRadius="3" Margin="0,0,8,0">
                            <Image Source="{Binding Thumbnail}" Stretch="Uniform"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                            <TextBlock Opacity="0.6">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding PrimaryFile.Extension}"/>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Opacity="0.5" FontSize="11"
                                       Visibility="{Binding HasSidecars, Converter={StaticResource BoolToVisConverter}}">
                                <Run Text="+"/>
                                <Run Text="{Binding SidecarFiles.Count, Mode=OneWay}"/>
                                <Run Text="sidecar(s)"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
