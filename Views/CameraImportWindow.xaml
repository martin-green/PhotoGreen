<Window x:Class="PhotoGreen.Views.CameraImportWindow"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
Title="Import from Camera" Height="580" Width="520"
WindowStartupLocation="CenterOwner"
Background="#1E1E1E" Foreground="#E0E0E0"
ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Destination Settings -->
        <GroupBox Grid.Row="0" Header="Destination">
            <StackPanel>
                <TextBlock Text="Import folder:" Margin="0,0,0,4"/>
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="Browse..."
                            Command="{Binding BrowseDestinationCommand}" Margin="6,0,0,0"/>
                    <TextBox Text="{Binding DestinationFolder, UpdateSourceTrigger=PropertyChanged}"/>
                </DockPanel>

                <TextBlock Text="Folder naming pattern:" Margin="0,10,0,4"/>
                <TextBox Text="{Binding FolderPattern, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Margin="0,4,0,0" Foreground="#888" FontSize="11">
                    <Run Text="Preview: "/><Run Text="{Binding PatternPreview, Mode=OneWay}" Foreground="#AAD4AA"/>
                    <LineBreak/>
                    <Run Text="Tokens: {yyyy} {MM} {dd} {HH} {mm}"/>
                </TextBlock>
            </StackPanel>
        </GroupBox>

        <!-- Camera Source -->
        <GroupBox Grid.Row="1" Header="USB Camera / PTP Device">
            <StackPanel>
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="Refresh"
                            Command="{Binding RefreshSourcesCommand}" Margin="6,0,0,0"/>
                    <ComboBox ItemsSource="{Binding Sources}"
                              SelectedItem="{Binding SelectedSource}"
                              DisplayMemberPath="DisplayName"/>
                </DockPanel>

                <Button Content="Import from Camera" Margin="0,8,0,0"
                        Command="{Binding ImportFromCameraCommand}"
                        HorizontalAlignment="Left"/>

                <CheckBox Content="Auto-import when camera connects"
                          IsChecked="{Binding AutoImportOnConnect}" Margin="0,6,0,0"/>
            </StackPanel>
        </GroupBox>

        <!-- Manual / WiFi Source -->
        <GroupBox Grid.Row="2" Header="Manual / WiFi / Network Import">
            <StackPanel>
                <TextBlock TextWrapping="Wrap" Foreground="#AAA" FontSize="11" Margin="0,0,0,6">
                    For WiFi-connected cameras, use the camera's built-in WiFi transfer to
                    a folder on your PC, or mount a network share, then select that folder below.
                </TextBlock>
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="Browse..."
                            Command="{Binding BrowseManualSourceCommand}" Margin="6,0,0,0"/>
                    <TextBox Text="{Binding ManualSourcePath, UpdateSourceTrigger=PropertyChanged}"/>
                </DockPanel>

                <Button Content="Import from Folder" Margin="0,8,0,0"
                        Command="{Binding ImportFromFolderCommand}"
                        HorizontalAlignment="Left"/>
            </StackPanel>
        </GroupBox>

        <!-- Progress -->
        <GroupBox Grid.Row="3" Header="Progress">
            <StackPanel>
                <ProgressBar Height="18" Minimum="0" Maximum="100" Value="{Binding ImportProgress}"/>
                <TextBlock Text="{Binding StatusText}" Margin="0,6,0,0"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </GroupBox>


        <!-- Cancel -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel Import" Command="{Binding CancelImportCommand}"
                    Visibility="{Binding IsImporting, Converter={StaticResource BoolToVisConverter}}"
                    Margin="0,0,8,0"/>
            <Button Content="Close" Click="CloseButton_Click"/>
        </StackPanel>

        <!-- Log -->
        <GroupBox Grid.Row="5" Header="Log">
            <ListBox ItemsSource="{Binding LogEntries}"
                     FontFamily="Consolas" FontSize="11"
                     Background="#1A1A1A" Foreground="#BBB" BorderThickness="0"
                     x:Name="LogList"/>
        </GroupBox>
    </Grid>
</Window>
