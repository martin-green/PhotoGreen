<UserControl x:Class="PhotoGreen.Views.ImageViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:PhotoGreen.Views">
    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#2D2D2D" Padding="4">
            <StackPanel Orientation="Horizontal">
                <Button Content="-" Width="28" Height="28" Command="{Binding ZoomOutCommand}"
                        ToolTip="Zoom Out" Margin="0,0,2,0"/>
                <TextBlock VerticalAlignment="Center" Foreground="#CCC" Width="50"
                           TextAlignment="Center" Margin="2,0">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0:P0}">
                            <Binding Path="ZoomLevel"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
                <Button Content="+" Width="28" Height="28" Command="{Binding ZoomInCommand}"
                        ToolTip="Zoom In" Margin="2,0,2,0"/>
                <Button Content="Fit" Height="28" Padding="8,0" Command="{Binding ZoomFitCommand}"
                        ToolTip="Fit to Window" Margin="2,0,2,0"/>
                <Button Content="1:1" Height="28" Padding="8,0" Command="{Binding ZoomActualCommand}"
                        ToolTip="Actual Pixels" Margin="2,0,8,0"/>
                <Separator/>
                <Button Content="Hist" Height="28" Padding="6,0" Command="{Binding ToggleHistogramCommand}"
                        ToolTip="Toggle Histogram" Margin="8,0,0,0"/>
                <Button x:Name="SelectButton" Height="28" Padding="6,0" Command="{Binding ToggleSelectCommand}"
                        ToolTip="Select region for Auto (Shift+drag)" Margin="4,0,0,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Content" Value="Select"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSelecting}" Value="True">
                                    <Setter Property="Content" Value="Cancel"/>
                                    <Setter Property="Background" Value="#0078D4"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>

        <!-- Zoomable image display -->
        <ScrollViewer x:Name="ImageScrollViewer" Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="#1E1E1E"
                      PreviewMouseWheel="ImageScrollViewer_PreviewMouseWheel"
                      PreviewMouseLeftButtonDown="ImageScrollViewer_MouseLeftButtonDown"
                      PreviewMouseLeftButtonUp="ImageScrollViewer_MouseLeftButtonUp"
                      PreviewMouseMove="ImageScrollViewer_MouseMove">
            <Grid x:Name="ImageContainer">
                <Grid.LayoutTransform>
                    <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1"/>
                </Grid.LayoutTransform>
                <Image x:Name="MainImage" Source="{Binding DisplayImage}" Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </Grid>
        </ScrollViewer>

        <!-- Selection rectangle overlay -->
        <Canvas x:Name="SelectionCanvas" Grid.Row="1" IsHitTestVisible="False">
            <Rectangle x:Name="SelectionRectangle" Stroke="#0078D4" StrokeThickness="1.5"
                       StrokeDashArray="4 2" Fill="#200078D4" Visibility="Collapsed"/>
        </Canvas>

        <!-- Histogram overlay (bottom-right corner) -->
        <views:HistogramControl Grid.Row="1"
                                Width="260" Height="140"
                                Margin="0,0,16,16"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Histogram="{Binding Histogram}"
                                Visibility="{Binding ShowHistogram, Converter={StaticResource BoolToVisConverter}}"/>

        <!-- Loading overlay -->
        <Border Grid.Row="1" Background="#80000000"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisConverter}}">
            <TextBlock Text="Loading..." Foreground="White" FontSize="18"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- Processing progress bar -->
        <ProgressBar Grid.Row="1" IsIndeterminate="True"
                     Height="3" VerticalAlignment="Top"
                     Background="Transparent" BorderThickness="0"
                     Foreground="#0078D4"
                     Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisConverter}}"/>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#2D2D2D" Padding="8,4">
            <TextBlock Text="{Binding StatusText}" Foreground="#CCC" FontSize="12"/>
        </Border>
    </Grid>
</UserControl>
