<UserControl x:Class="PhotoGreen.Views.LibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:PhotoGreen.Models">
    <Grid Background="#1E1E1E">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" MinWidth="180"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="260" MinWidth="200"/>
        </Grid.ColumnDefinitions>

        <!-- ===== SIDEBAR ===== -->
        <Grid Grid.Column="0" Background="#252525">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Root Folder -->
            <StackPanel Grid.Row="0" Margin="8,8,8,4">
                <TextBlock Text="📁 Library Root" FontWeight="Bold" Foreground="#DDD" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding RootFolder, TargetNullValue='(none selected)'}"
                           Foreground="#AAA" TextTrimming="CharacterEllipsis" Margin="0,0,0,4"/>
                <Button Content="Browse..." Command="{Binding BrowseFolderCommand}"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
            </StackPanel>

            <Border Grid.Row="1" Height="1" Background="#444" Margin="8,4"/>

            <!-- Group By -->
            <StackPanel Grid.Row="2" Margin="8,4">
                <TextBlock Text="Group by" FontWeight="Bold" Foreground="#DDD" Margin="0,0,0,4"/>
                <RadioButton Content="📂 Folder" Foreground="#CCC" Margin="0,2"
                             IsChecked="{Binding GroupMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static models:LibraryGroupMode.Folder}}"/>
                <RadioButton Content="👤 Faces" Foreground="#CCC" Margin="0,2"
                             IsChecked="{Binding GroupMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static models:LibraryGroupMode.Faces}}"/>
                <RadioButton Content="📋 Duplicates" Foreground="#CCC" Margin="0,2"
                             IsChecked="{Binding GroupMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static models:LibraryGroupMode.Duplicates}}"/>
                <RadioButton Content="🏷️ Tags" Foreground="#CCC" Margin="0,2"
                             IsChecked="{Binding GroupMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static models:LibraryGroupMode.Tags}}"/>
            </StackPanel>

            <Border Grid.Row="3" Height="1" Background="#444" Margin="8,4"/>

            <!-- Scan Controls -->
            <StackPanel Grid.Row="4" Margin="8,4" VerticalAlignment="Top">
                <Button Content="🔍 Scan Library" Command="{Binding ScanLibraryCommand}"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Background="#2A4A2A" Foreground="#CCC" Margin="0,0,0,4"
                        Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisConverter}, ConverterParameter=Invert}"/>
                <Button Content="⏹ Cancel" Command="{Binding CancelScanCommand}"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Background="#4A2A2A" Foreground="#CCC" Margin="0,0,0,4"
                        Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisConverter}}"/>

                <ProgressBar Value="{Binding ScanProgress}" Minimum="0" Maximum="100"
                             Height="8" Margin="0,2"
                             Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisConverter}}"/>

                <TextBlock Text="{Binding ScanStatusText}" Foreground="#999" FontSize="11"
                           TextTrimming="CharacterEllipsis" Margin="0,4"/>

                <!-- AI Status -->
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="🤖 AI:" Foreground="#999" Margin="0,0,4,0"/>
                    <TextBlock Foreground="#999">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="🔴 Unavailable"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AiAvailable}" Value="True">
                                        <Setter Property="Text" Value="🟢 Connected"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center"
                      VerticalAlignment="Stretch" Cursor="SizeWE"/>

        <!-- ===== THUMBNAIL GRID ===== -->
        <ListBox Grid.Column="2" ItemsSource="{Binding Groups}"
                 Background="#1E1E1E" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 VirtualizingPanel.ScrollUnit="Pixel">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Focusable" Value="False"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="0,0,0,8">
                        <!-- Group Header -->
                        <Border Background="#2A2A2A" Padding="10,6" Margin="4,4,4,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold"
                                           FontSize="13" Foreground="#DDD"/>
                                <TextBlock Text="{Binding Count, StringFormat=' ({0})'}"
                                           Foreground="#999" FontSize="13" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Thumbnail Wrap -->
                        <ItemsControl ItemsSource="{Binding Items}"
                                      MaxHeight="560">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="130" Height="140" Margin="4"
                                            Background="#2D2D2D" BorderBrush="#444"
                                            BorderThickness="1" CornerRadius="3"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="OnThumbnailClick"
                                            MouseLeftButtonUp="OnThumbnailDoubleClick">
                                        <StackPanel>
                                            <Image Source="{Binding Thumbnail}"
                                                   Width="120" Height="100"
                                                   Stretch="Uniform" Margin="4,4,4,0"
                                                   RenderOptions.BitmapScalingMode="LowQuality"/>
                                            <TextBlock Text="{Binding FileName}"
                                                       Foreground="#AAA" FontSize="10"
                                                       TextTrimming="CharacterEllipsis"
                                                       HorizontalAlignment="Center"
                                                       Margin="4,2"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Splitter -->
        <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Center"
                      VerticalAlignment="Stretch" Cursor="SizeWE"/>

        <!-- ===== DETAIL PANEL ===== -->
        <Grid Grid.Column="4" Background="#252525">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="10">
                    <TextBlock Text="Image Details" FontWeight="Bold" FontSize="14"
                               Foreground="#DDD" Margin="0,0,0,8"/>
                    <Border Height="1" Background="#444" Margin="0,0,0,8"/>

                    <!-- File Name -->
                    <TextBlock Text="File" Foreground="#999" FontSize="11"/>
                    <TextBlock Text="{Binding DetailFileName, TargetNullValue='-'}"
                               Foreground="#CCC" TextWrapping="Wrap" Margin="0,0,0,8"/>

                    <!-- Description -->
                    <TextBlock Text="Description" Foreground="#999" FontSize="11"/>
                    <TextBlock Text="{Binding DetailDescription, TargetNullValue='-'}"
                               Foreground="#CCC" TextWrapping="Wrap" Margin="0,0,0,8"/>

                    <!-- Tags -->
                    <TextBlock Text="Tags" Foreground="#999" FontSize="11"/>
                    <TextBlock Text="{Binding DetailTags, TargetNullValue='-'}"
                               Foreground="#CCC" TextWrapping="Wrap" Margin="0,0,0,8"/>

                    <!-- Faces -->
                    <TextBlock Text="Faces" Foreground="#999" FontSize="11"/>
                    <TextBlock Text="{Binding DetailFaces, TargetNullValue='-'}"
                               Foreground="#CCC" TextWrapping="Wrap" Margin="0,0,0,8"/>

                    <!-- Duplicates -->
                    <TextBlock Text="Duplicates" Foreground="#999" FontSize="11"/>
                    <TextBlock Text="{Binding DetailDuplicateInfo, TargetNullValue='-'}"
                               Foreground="#CCC" TextWrapping="Wrap" Margin="0,0,0,12"/>

                    <Border Height="1" Background="#444" Margin="0,0,0,8"/>

                    <!-- Actions -->
                    <Button Content="✏️ Open in Editor" Command="{Binding OpenInEditorCommand}"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Margin="0,0,0,4"/>
                    <Button Content="🗑️ Delete Duplicates" Command="{Binding DeleteDuplicatesCommand}"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Background="#4A2A2A" Foreground="#CCC"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
